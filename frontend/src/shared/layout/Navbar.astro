---
import { currentLocale, localeUrl } from "@i18n/locales";
import { loadTranslations } from "@i18n/index";
import { navbarLinks } from "@config/site";
import { isLandingPage } from "@lib/urls";
import { toSlug } from "@lib/strings";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const locale = currentLocale(Astro.currentLocale);
const translations = await loadTranslations(locale);
const onLanding = isLandingPage(Astro.url);

function anchorFor(key: (typeof navbarLinks)[number]): string {
  const slug = toSlug(translations.navbar[key]);
  return onLanding ? `#${slug}` : localeUrl(locale, `/#${slug}`);
}
---

<header class="nav" role="banner">
  <a href={localeUrl(locale, "/")} class="nav__brand" aria-label="Homepage">
    <span class="nav__brand-mark" aria-hidden="true">○</span>
    <span class="nav__brand-name">Cristián R.</span>
    <span class="nav__brand-role eyebrow">F. S. Developer</span>
  </a>

  <nav class="nav__links" aria-label="Primary">
    {navbarLinks.map((key) => (
      <a class="nav__link" href={anchorFor(key)}>
        <span aria-hidden="true" class="nav__link-num"></span>
        {translations.navbar[key]}
      </a>
    ))}
  </nav>

  <div class="nav__right">
    <LanguageSwitcher />
    <button
      type="button"
      class="nav__menu-toggle"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle menu"
      id="nav-menu-toggle"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>
</header>

<nav class="nav__mobile" id="mobile-menu" aria-label="Mobile" hidden>
  <ol class="nav__mobile-list" role="list">
    {navbarLinks.map((key, i) => (
      <li class="nav__mobile-item">
        <a class="nav__mobile-link" href={anchorFor(key)} data-mobile-link>
          <span class="nav__mobile-num" aria-hidden="true">
            {String(i + 1).padStart(2, "0")}
          </span>
          <span class="nav__mobile-label display">{translations.navbar[key]}</span>
        </a>
      </li>
    ))}
  </ol>
</nav>

<style>
  :global(:root) {
    --nav-height: 4rem;
    --nav-bottom: 4rem;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background-color: rgba(11, 11, 15, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-ink-rule);
    min-width: 0;
    width: 100%;
  }

  /* Scroll-locking the page sets `position: fixed` on <body>, which
     detaches `position: sticky` ancestors. Without this, the nav
     (which contains the menu toggle that morphs into the close X)
     drops back to its in-document position and can scroll out of
     view — making the X "disappear", or briefly double up while the
     mobile URL bar collapses and sticky tries to recompute. Pinning
     the nav explicitly while the menu is open keeps the X anchored
     to the top of the visible area. */
  :global(html[data-nav-open]) .nav {
    position: fixed;
    top: 0;
    left: var(--space-md);
    right: var(--space-md);
  }

  .nav__brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-xs);
    color: var(--color-paper);
    text-decoration: none;
    min-width: 0;
    flex: 1 1 auto;
  }

  .nav__brand-mark {
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    line-height: 1;
  }

  .nav__brand-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-h3);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav__brand-role {
    display: none;
    color: var(--color-paper-mute);
  }

  .nav__links {
    display: none;
    align-items: center;
    /* Fluid gap so the link row decompresses smoothly between the
       900px desktop activation and ~1700px+ where it caps at xl. */
    gap: clamp(var(--space-md), 1.6vw, var(--space-xl));
    counter-reset: link;
  }

  .nav__link {
    counter-increment: link;
    color: var(--color-paper-soft);
    font-size: var(--fs-small);
    font-weight: var(--fw-regular);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .nav__link::before {
    content: counter(link, decimal-leading-zero) " · ";
    color: var(--color-paper-mute);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    letter-spacing: var(--tracking-wide);
  }

  /* In the 900-1099 narrow-desktop zone the counter prefix
     ("01 · ") on each link adds ~35px of visual density per link
     and pushes the row back into the cramped feel the user
     reported. Drop it until ~1100px, where there's room again. */
  @media (max-width: 1099px) {
    .nav__link::before {
      content: none;
    }
  }

  .nav__link:hover {
    color: var(--color-paper);
  }

  .nav__right {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    flex-shrink: 0;
    /* Past the cramped 900-1099 zone, add proportional separation
       between the link cluster and the language/CTA group so they
       read as distinct landmarks instead of adjacent items in the
       same row. The brand's `flex: 1 1 auto` would otherwise hog
       all leftover space and leave only the base gap (16px) here. */
    margin-inline-start: clamp(0px, calc((100vw - 1100px) * 0.045), var(--space-2xl));
  }

  .nav__menu-toggle {
    width: 40px;
    height: 40px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: transparent;
    border: 1px solid var(--color-ink-rule);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .nav__menu-toggle:hover {
    border-color: var(--color-paper-soft);
  }

  .nav__menu-toggle span {
    display: block;
    width: 18px;
    height: 1px;
    background: var(--color-paper);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .nav__menu-toggle[aria-expanded="true"] span:first-child {
    transform: translateY(2.5px) rotate(45deg);
  }

  .nav__menu-toggle[aria-expanded="true"] span:last-child {
    transform: translateY(-2.5px) rotate(-45deg);
  }

  .nav__menu-toggle[aria-expanded="true"] {
    border-color: var(--color-paper-soft);
  }

  .nav__mobile {
    position: fixed;
    /* Pin to the visual viewport (set by the script below) so the
       overlay tracks the visible area exactly as the mobile URL/
       search bar shows, hides, or animates between the two. The
       dvh/dvw fallback covers the brief moment before JS runs and
       any engine without visualViewport — both `100dvh` and
       `100dvw` already adjust to dynamic browser chrome. */
    top: var(--vv-y, 0px);
    left: var(--vv-x, 0px);
    width: var(--vv-w, 100dvw);
    height: var(--vv-h, 100dvh);
    z-index: calc(var(--z-nav) - 1);
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    padding-top: calc(var(--nav-bottom) + var(--space-md));
    padding-bottom: max(var(--space-md), env(safe-area-inset-bottom, 0px));
    background-color: rgba(11, 11, 15, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    opacity: 0;
    pointer-events: none;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    transition: opacity var(--dur-base) var(--ease-out);
  }

  .nav__mobile[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  .nav__mobile-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-width: 0;
  }

  .nav__mobile-item {
    border-top: 1px solid var(--color-ink-rule);
  }

  .nav__mobile-item:last-child {
    border-bottom: 1px solid var(--color-ink-rule);
  }

  .nav__mobile-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-2xs);
    color: var(--color-paper);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
    width: 100%;
    min-width: 0;
  }

  .nav__mobile-link:hover,
  .nav__mobile-link:focus-visible {
    color: var(--color-accent);
  }

  .nav__mobile-num {
    flex-shrink: 0;
    width: 2.5rem;
    color: var(--color-paper-mute);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    letter-spacing: var(--tracking-wide);
  }

  .nav__mobile-label {
    min-width: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--fw-regular);
    font-size: var(--fs-h1);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    overflow-wrap: anywhere;
  }

  @media (max-width: 460px) {
    .nav {
      padding-inline: var(--space-md);
    }

    .nav__brand-name {
      font-size: clamp(1.1rem, 4.8vw, var(--fs-h3));
    }

    .nav__right {
      gap: var(--space-xs);
    }

    .nav__mobile-label {
      font-size: clamp(1.8rem, 9vw, var(--fs-h1));
    }
  }

  @media (min-width: 900px) {
    /* Once the link row turns on, align all three flex items to a
       shared text baseline. Center alignment was making the lang
       switcher (12px mono with extra padding) drift vertically
       out of step with the nav links (14px body) — the glyphs of
       both texts now rest on the same horizontal line. Mobile
       keeps center alignment because the toggle button has no
       text baseline. */
    .nav {
      align-items: baseline;
    }
    .nav__links {
      display: inline-flex;
    }
    .nav__menu-toggle {
      display: none;
    }
    .nav__mobile {
      display: none !important;
    }
  }

  /* Defer the long brand eyebrow ("F. S. Developer") until there's
     real horizontal room for it. Below 1400px the row already
     carries 5 nav-links and the language switcher; showing the
     role here forces the brand-name into ellipsis truncation,
     which reads as the navbar "shrinking" as the viewport narrows. */
  @media (min-width: 1400px) {
    .nav__brand-role {
      display: inline;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const body = document.body;
  let lockedScrollY = 0;

  const setViewportVars = () => {
    const vv = window.visualViewport;
    if (!vv) return;
    const root = document.documentElement;
    root.style.setProperty("--vv-x", `${vv.offsetLeft}px`);
    root.style.setProperty("--vv-y", `${vv.offsetTop}px`);
    root.style.setProperty("--vv-w", `${vv.width}px`);
    root.style.setProperty("--vv-h", `${vv.height}px`);
  };

  const setNavHeight = () => {
    const nav = document.querySelector<HTMLElement>(".nav");
    if (!nav) return;
    const { height, bottom } = nav.getBoundingClientRect();
    document.documentElement.style.setProperty("--nav-height", `${Math.ceil(height)}px`);
    document.documentElement.style.setProperty("--nav-bottom", `${Math.ceil(bottom)}px`);
  };

  const lockScroll = () => {
    lockedScrollY = window.scrollY;
    body.style.position = "fixed";
    body.style.top = `-${lockedScrollY}px`;
    body.style.left = "0";
    body.style.right = "0";
    body.style.width = "100%";
  };

  const unlockScroll = () => {
    body.style.position = "";
    body.style.top = "";
    body.style.left = "";
    body.style.right = "";
    body.style.width = "";
    if (lockedScrollY > 0) window.scrollTo({ top: lockedScrollY });
    lockedScrollY = 0;
  };

  setViewportVars();
  setNavHeight();
  window.visualViewport?.addEventListener("resize", setViewportVars, { passive: true });
  window.visualViewport?.addEventListener("scroll", setViewportVars, { passive: true });
  window.addEventListener("resize", setViewportVars, { passive: true });
  window.addEventListener("orientationchange", setViewportVars);
  window.addEventListener("resize", setNavHeight, { passive: true });
  window.addEventListener("orientationchange", setNavHeight);
  document.addEventListener("astro:page-load", setViewportVars);
  document.addEventListener("astro:after-swap", setViewportVars);
  document.addEventListener("astro:page-load", setNavHeight);
  document.addEventListener("astro:after-swap", setNavHeight);

  if (toggle && menu) {
    const close = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.removeAttribute("data-open");
      menu.setAttribute("hidden", "");
      document.documentElement.removeAttribute("data-nav-open");
      unlockScroll();
      setViewportVars();
      setNavHeight();
    };
    const open = () => {
      setViewportVars();
      setNavHeight();
      toggle.setAttribute("aria-expanded", "true");
      menu.removeAttribute("hidden");
      document.documentElement.setAttribute("data-nav-open", "true");
      lockScroll();
      requestAnimationFrame(() => menu.setAttribute("data-open", "true"));
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? close() : open();
    });

    close();

    document.addEventListener("astro:page-load", close);
    document.addEventListener("astro:after-swap", close);
    window.addEventListener("pageshow", close);

    document.addEventListener("click", (e) => {
      if (toggle.getAttribute("aria-expanded") !== "true") return;
      if (menu.contains(e.target as Node) || toggle.contains(e.target as Node)) return;
      close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") close();
    });

    menu
      .querySelectorAll<HTMLAnchorElement>("[data-mobile-link]")
      .forEach((a) => a.addEventListener("click", close));
  }
</script>
