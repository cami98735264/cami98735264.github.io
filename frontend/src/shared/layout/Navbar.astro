---
import { getLocale, getLocaleUrl } from "astro-i18n-aut";
import { loadTranslations } from "@i18n/index";
import { navbarLinks } from "@config/site";
import { isLandingPage } from "@lib/urls";
import { toSlug } from "@lib/strings";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const locale = getLocale(Astro.url);
const translations = await loadTranslations(locale);
const onLanding = isLandingPage(Astro.url);

function anchorFor(key: (typeof navbarLinks)[number]): string {
  const slug = toSlug(translations.navbar[key]);
  return onLanding ? `#${slug}` : getLocaleUrl(`/#${slug}`, locale);
}
---

<header class="nav" role="banner">
  <a href={getLocaleUrl("/", locale)} class="nav__brand" aria-label="Homepage">
    <span class="nav__brand-mark" aria-hidden="true">○</span>
    <span class="nav__brand-name">Cristián R.</span>
    <span class="nav__brand-role eyebrow">F. S. Developer</span>
  </a>

  <nav class="nav__links" aria-label="Primary">
    {navbarLinks.map((key) => (
      <a class="nav__link" href={anchorFor(key)}>
        <span aria-hidden="true" class="nav__link-num"></span>
        {translations.navbar[key]}
      </a>
    ))}
  </nav>

  <div class="nav__right">
    <LanguageSwitcher />
    <button
      type="button"
      class="nav__menu-toggle"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Toggle menu"
      id="nav-menu-toggle"
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>
</header>

<nav class="nav__mobile" id="mobile-menu" aria-label="Mobile" hidden>
  <ol class="nav__mobile-list" role="list">
    {navbarLinks.map((key, i) => (
      <li class="nav__mobile-item">
        <a class="nav__mobile-link" href={anchorFor(key)} data-mobile-link>
          <span class="nav__mobile-num" aria-hidden="true">
            {String(i + 1).padStart(2, "0")}
          </span>
          <span class="nav__mobile-label display">{translations.navbar[key]}</span>
        </a>
      </li>
    ))}
  </ol>
</nav>

<style>
  :global(:root) {
    --nav-height: 4rem;
    --nav-bottom: 4rem;
    --app-vw: 100vw;
    --app-vh: 100dvh;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background-color: rgba(11, 11, 15, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-ink-rule);
    min-width: 0;
    width: min(100%, var(--app-vw));
  }

  .nav__brand {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-xs);
    color: var(--color-paper);
    text-decoration: none;
    min-width: 0;
    flex: 1 1 auto;
  }

  .nav__brand-mark {
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    line-height: 1;
  }

  .nav__brand-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-h3);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav__brand-role {
    display: none;
    color: var(--color-paper-mute);
  }

  .nav__links {
    display: none;
    align-items: center;
    gap: var(--space-xl);
    counter-reset: link;
  }

  .nav__link {
    counter-increment: link;
    color: var(--color-paper-soft);
    font-size: var(--fs-small);
    font-weight: var(--fw-regular);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .nav__link::before {
    content: counter(link, decimal-leading-zero) " · ";
    color: var(--color-paper-mute);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    letter-spacing: var(--tracking-wide);
  }

  .nav__link:hover {
    color: var(--color-paper);
  }

  .nav__right {
    display: inline-flex;
    align-items: center;
    gap: var(--space-md);
    flex-shrink: 0;
  }

  .nav__menu-toggle {
    width: 40px;
    height: 40px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: transparent;
    border: 1px solid var(--color-ink-rule);
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .nav__menu-toggle:hover {
    border-color: var(--color-paper-soft);
  }

  .nav__menu-toggle span {
    display: block;
    width: 18px;
    height: 1px;
    background: var(--color-paper);
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .nav__menu-toggle[aria-expanded="true"] span:first-child {
    transform: translateY(2.5px) rotate(45deg);
  }
  .nav__menu-toggle[aria-expanded="true"] span:last-child {
    transform: translateY(-2.5px) rotate(-45deg);
  }

  .nav__mobile {
    position: fixed;
    top: var(--nav-bottom);
    right: env(safe-area-inset-right, 0px);
    bottom: 0;
    left: env(safe-area-inset-left, 0px);
    z-index: calc(var(--z-nav) - 1);
    display: flex;
    flex-direction: column;
    width: min(100%, var(--app-vw));
    max-width: 100%;
    min-height: 0;
    max-height: calc(var(--app-vh) - var(--nav-bottom));
    padding: var(--space-md);
    padding-bottom: max(var(--space-md), env(safe-area-inset-bottom, 0px));
    background-color: rgba(11, 11, 15, 0.96);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    opacity: 0;
    pointer-events: none;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    transition: opacity var(--dur-base) var(--ease-out);
  }

  .nav__mobile[data-open="true"] {
    opacity: 1;
    pointer-events: auto;
  }

  .nav__mobile-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-width: 0;
  }

  .nav__mobile-item {
    border-top: 1px solid var(--color-ink-rule);
  }

  .nav__mobile-item:last-child {
    border-bottom: 1px solid var(--color-ink-rule);
  }

  .nav__mobile-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-2xs);
    color: var(--color-paper);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
    width: 100%;
    min-width: 0;
  }

  .nav__mobile-link:hover,
  .nav__mobile-link:focus-visible {
    color: var(--color-accent);
  }

  .nav__mobile-num {
    flex-shrink: 0;
    width: 2.5rem;
    color: var(--color-paper-mute);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    letter-spacing: var(--tracking-wide);
  }

  .nav__mobile-label {
    min-width: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--fw-regular);
    font-size: var(--fs-h1);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    overflow-wrap: anywhere;
  }

  @media (max-width: 460px) {
    .nav {
      padding-inline: var(--space-md);
    }

    .nav__brand-name {
      font-size: clamp(1.1rem, 4.8vw, var(--fs-h3));
    }

    .nav__right {
      gap: var(--space-xs);
    }

    .nav__mobile-label {
      font-size: clamp(1.8rem, 9vw, var(--fs-h1));
    }
  }

  @media (min-width: 900px) {
    .nav__brand-role {
      display: inline;
    }
    .nav__links {
      display: inline-flex;
    }
    .nav__menu-toggle {
      display: none;
    }
    .nav__mobile {
      display: none !important;
    }
  }
</style>

<script>
  const toggle = document.getElementById("nav-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const body = document.body;
  let lockedScrollY = 0;

  const setViewportVars = () => {
    const vv = window.visualViewport;
    const width = vv?.width ?? window.innerWidth;
    const height = vv?.height ?? window.innerHeight;
    document.documentElement.style.setProperty("--app-vw", `${Math.round(width)}px`);
    document.documentElement.style.setProperty("--app-vh", `${Math.round(height)}px`);
  };

  const setNavHeight = () => {
    const nav = document.querySelector<HTMLElement>(".nav");
    if (!nav) return;
    const { height, bottom } = nav.getBoundingClientRect();
    document.documentElement.style.setProperty("--nav-height", `${Math.ceil(height)}px`);
    document.documentElement.style.setProperty("--nav-bottom", `${Math.ceil(bottom)}px`);
  };

  const lockScroll = () => {
    lockedScrollY = window.scrollY;
    body.style.position = "fixed";
    body.style.top = `-${lockedScrollY}px`;
    body.style.left = "0";
    body.style.right = "0";
    body.style.width = "100%";
  };

  const unlockScroll = () => {
    body.style.position = "";
    body.style.top = "";
    body.style.left = "";
    body.style.right = "";
    body.style.width = "";
    if (lockedScrollY > 0) window.scrollTo({ top: lockedScrollY });
    lockedScrollY = 0;
  };

  setViewportVars();
  setNavHeight();
  window.visualViewport?.addEventListener("resize", setViewportVars, { passive: true });
  window.visualViewport?.addEventListener("scroll", setViewportVars, { passive: true });
  window.addEventListener("resize", setViewportVars, { passive: true });
  window.addEventListener("orientationchange", setViewportVars);
  window.addEventListener("resize", setNavHeight, { passive: true });
  window.addEventListener("orientationchange", setNavHeight);
  document.addEventListener("astro:page-load", setViewportVars);
  document.addEventListener("astro:after-swap", setViewportVars);
  document.addEventListener("astro:page-load", setNavHeight);
  document.addEventListener("astro:after-swap", setNavHeight);

  if (toggle && menu) {
    const close = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.removeAttribute("data-open");
      menu.setAttribute("hidden", "");
      document.documentElement.removeAttribute("data-nav-open");
      unlockScroll();
      setViewportVars();
      setNavHeight();
    };
    const open = () => {
      setViewportVars();
      setNavHeight();
      toggle.setAttribute("aria-expanded", "true");
      menu.removeAttribute("hidden");
      document.documentElement.setAttribute("data-nav-open", "true");
      lockScroll();
      requestAnimationFrame(() => menu.setAttribute("data-open", "true"));
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? close() : open();
    });

    close();

    document.addEventListener("astro:page-load", close);
    document.addEventListener("astro:after-swap", close);
    window.addEventListener("pageshow", close);

    document.addEventListener("click", (e) => {
      if (toggle.getAttribute("aria-expanded") !== "true") return;
      if (menu.contains(e.target as Node) || toggle.contains(e.target as Node)) return;
      close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") close();
    });

    menu
      .querySelectorAll<HTMLAnchorElement>("[data-mobile-link]")
      .forEach((a) => a.addEventListener("click", close));
  }
</script>
