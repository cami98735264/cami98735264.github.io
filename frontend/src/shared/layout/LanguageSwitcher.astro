---
import { currentLocale, switchUrl } from "@i18n/locales";
import { loadTranslations } from "@i18n/index";

const locale = currentLocale(Astro.currentLocale);
const translations = await loadTranslations(locale);
const targets: Array<{ code: "es" | "en"; label: string }> = [
  { code: "es", label: translations.navbar.languageInput.options.es },
  { code: "en", label: translations.navbar.languageInput.options.en },
];
---

<div class="lang" role="group" aria-label="Language">
  {targets.map(({ code, label }) => (
    <a
      href={switchUrl(Astro.url.pathname, code)}
      class:list={["lang__opt", code === locale && "is-active"]}
      aria-current={code === locale ? "true" : undefined}
      hreflang={code}
    >
      <span class="lang__code">{code}</span>
      <span class="lang__label">{label}</span>
    </a>
  ))}
</div>

<style>
  .lang {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    letter-spacing: var(--tracking-wide);
  }

  .lang__opt {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2xs);
    padding: var(--space-2xs) var(--space-xs);
    color: var(--color-paper-mute);
    text-decoration: none;
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .lang__opt:hover {
    color: var(--color-paper);
  }

  .lang__opt.is-active {
    color: var(--color-accent);
  }

  .lang__label {
    display: none;
  }

  /* Match the navbar's brand-role threshold — below 1400px the row
     is tight, so keep just the two-letter codes (ES / EN). Labels
     come back once there's room for the full word. */
  @media (min-width: 1400px) {
    .lang__label {
      display: inline;
      color: var(--color-paper-mute);
    }
    .lang__opt.is-active .lang__label {
      color: var(--color-paper-soft);
    }
  }
</style>
