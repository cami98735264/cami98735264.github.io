---
interface Props {
  label?: string;
  class?: string;
}
const { label, class: className = "" } = Astro.props;
---

<div class:list={["rule", className]} role="separator" aria-orientation="horizontal">
  <span class="rule__line"></span>
  {label && <span class="rule__label eyebrow">{label}</span>}
  {label && <span class="rule__line"></span>}
</div>

<style>
  .rule {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    width: 100%;
  }

  .rule__line {
    flex: 1;
    height: 1px;
    background: var(--color-ink-rule);
  }

  .rule__label {
    flex-shrink: 0;
    color: var(--color-paper-mute);
    font-size: var(--fs-caption);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-family: var(--font-mono);
  }
</style>
