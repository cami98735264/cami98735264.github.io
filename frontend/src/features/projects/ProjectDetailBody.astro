---
import type { Project } from "./project.types";

interface Props {
  project: Project;
  highlightTitle: string;
}

const { project, highlightTitle } = Astro.props;
const screenshots = project.screenshots;
const total = screenshots.length;
const half = Math.ceil(total / 2);
const before = screenshots.slice(0, half);
const after = screenshots.slice(half);
---

<article class="pb">
  <section class="pb__gallery" aria-label="Screenshots — first half">
    {before.map((src, i) => (
      <button
        type="button"
        class="pb__shot reveal"
        style={`--reveal-delay: ${i * 60}ms`}
        data-lightbox-trigger
        data-index={i}
        aria-label={`Open screenshot ${i + 1} of ${total}`}
        aria-haspopup="dialog"
      >
        <img src={src} alt="" loading="lazy" decoding="async" />
        <span class="pb__shot-zoom" aria-hidden="true">⤢</span>
      </button>
    ))}
  </section>

  <section class="pb__notes">
    <h2 class="pb__notes-title display reveal">{highlightTitle}</h2>
    <ol class="pb__notes-list" role="list">
      {project.projectNotes.map((note, i) => (
        <li class="pb__note reveal" data-motion="side" style={`--reveal-delay: ${i * 80}ms`}>
          <span class="pb__note-num eyebrow" aria-hidden="true">
            {String(i + 1).padStart(2, "0")}
          </span>
          <p class="pb__note-text">{note}</p>
        </li>
      ))}
    </ol>
  </section>

  {after.length > 0 && (
    <section class="pb__gallery" aria-label="Screenshots — second half">
      {after.map((src, i) => (
        <button
          type="button"
          class="pb__shot reveal"
          style={`--reveal-delay: ${i * 60}ms`}
          data-lightbox-trigger
          data-index={half + i}
          aria-label={`Open screenshot ${half + i + 1} of ${total}`}
          aria-haspopup="dialog"
        >
          <img src={after[i]} alt="" loading="lazy" decoding="async" />
          <span class="pb__shot-zoom" aria-hidden="true">⤢</span>
        </button>
      ))}
    </section>
  )}

  <dialog class="lb" id="lightbox" aria-label="Screenshot preview">
    <div class="lb__inner">
      <header class="lb__bar">
        <span class="lb__counter eyebrow" data-lightbox-counter>01 / {String(total).padStart(2, "0")}</span>
        <button type="button" class="lb__close" data-lightbox-close aria-label="Close preview">
          <svg class="lb__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>
      </header>
      <div class="lb__stage">
        <button type="button" class="lb__nav lb__nav--prev" data-lightbox-prev aria-label="Previous screenshot">
          <svg class="lb__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" />
          </svg>
        </button>
        <img class="lb__img" data-lightbox-img alt="" />
        <button type="button" class="lb__nav lb__nav--next" data-lightbox-next aria-label="Next screenshot">
          <svg class="lb__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 6l6 6-6 6" />
          </svg>
        </button>
      </div>
    </div>
  </dialog>
</article>

<style>
  .pb {
    width: 100%;
    max-width: var(--container-full);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: var(--space-2xl) var(--space-5xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }

  .pb__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(360px, 100%), 1fr));
    gap: var(--space-md);
  }

  .pb__shot {
    position: relative;
    margin: 0;
    padding: 0;
    aspect-ratio: 16 / 10;
    background: var(--color-ink-soft);
    border: 1px solid var(--color-ink-rule);
    overflow: hidden;
    cursor: zoom-in;
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .pb__shot:hover,
  .pb__shot:focus-visible {
    border-color: var(--color-paper-soft);
  }

  .pb__shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
    pointer-events: none;
  }

  .pb__shot:hover img,
  .pb__shot:focus-visible img {
    transform: scale(1.02);
  }

  .pb__shot-zoom {
    position: absolute;
    bottom: var(--space-sm);
    right: var(--space-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(11, 11, 15, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-ink-rule);
    border-radius: var(--radius-pill);
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    line-height: 1;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
    pointer-events: none;
  }

  .pb__shot:hover .pb__shot-zoom,
  .pb__shot:focus-visible .pb__shot-zoom {
    opacity: 1;
    transform: translateY(0);
  }

  .pb__notes {
    display: grid;
    gap: var(--space-xl);
  }

  .pb__notes-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--fw-regular);
    font-size: var(--fs-h2);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-paper);
    text-wrap: balance;
    max-width: 14ch;
  }

  .pb__notes-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-xl);
  }

  .pb__note {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: var(--space-md);
    padding-block: var(--space-md);
    border-top: 1px solid var(--color-ink-rule);
  }

  .pb__note:last-child {
    border-bottom: 1px solid var(--color-ink-rule);
  }

  .pb__note-num {
    color: var(--color-accent);
  }

  .pb__note-text {
    color: var(--color-paper-soft);
    font-size: var(--fs-body);
    line-height: var(--lh-loose);
    max-width: 70ch;
  }

  @media (min-width: 900px) {
    .pb__notes {
      grid-template-columns: minmax(280px, 1fr) 2fr;
      align-items: start;
      gap: var(--space-3xl);
    }
    .pb__notes-title {
      position: sticky;
      top: var(--space-3xl);
    }
  }

  /* ============================================================
     Lightbox
     ============================================================ */
  .lb {
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
    border: 0;
    color: var(--color-paper);
  }

  .lb::backdrop {
    background-color: rgba(11, 11, 15, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .lb[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .lb[open] .lb__inner {
      animation: lb-in 240ms var(--ease-out) both;
    }
    @keyframes lb-in {
      from { opacity: 0; transform: scale(0.98); }
      to   { opacity: 1; transform: none; }
    }
  }

  .lb__inner {
    width: min(100%, var(--container-full));
    height: 100%;
    padding: var(--space-md);
    display: grid;
    grid-template-rows: auto 1fr;
    gap: var(--space-md);
  }

  .lb__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .lb__counter {
    color: var(--color-paper-mute);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    letter-spacing: var(--tracking-wide);
  }

  .lb__close {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-ink-rule);
    border-radius: var(--radius-pill);
    color: var(--color-paper);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }

  .lb__icon {
    display: block;
  }

  .lb__close:hover,
  .lb__close:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .lb__stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }

  .lb__img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    background: var(--color-ink-soft);
    border: 1px solid var(--color-ink-rule);
  }

  .lb__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(11, 11, 15, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--color-ink-rule);
    border-radius: var(--radius-pill);
    color: var(--color-paper);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .lb__nav--prev { left: var(--space-md); }
  .lb__nav--next { right: var(--space-md); }

  .lb__nav:hover,
  .lb__nav:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .lb__nav--prev:hover { transform: translate(-3px, -50%); }
  .lb__nav--next:hover { transform: translate(3px, -50%); }

  .lb__nav[disabled] {
    opacity: 0.3;
    cursor: not-allowed;
  }
</style>

<script is:inline define:vars={{ screenshots, total }}>
  (() => {
    const dialog = document.getElementById("lightbox");
    if (!dialog || !screenshots?.length) return;

    const img = dialog.querySelector("[data-lightbox-img]");
    const counter = dialog.querySelector("[data-lightbox-counter]");
    const closeBtn = dialog.querySelector("[data-lightbox-close]");
    const prevBtn = dialog.querySelector("[data-lightbox-prev]");
    const nextBtn = dialog.querySelector("[data-lightbox-next]");
    const triggers = document.querySelectorAll("[data-lightbox-trigger]");

    let currentIndex = 0;
    let lastFocused = null;

    const setIndex = (i) => {
      currentIndex = (i + total) % total;
      img.src = screenshots[currentIndex];
      img.alt = `Screenshot ${currentIndex + 1} of ${total}`;
      counter.textContent = `${String(currentIndex + 1).padStart(2, "0")} / ${String(total).padStart(2, "0")}`;
    };

    const open = (i) => {
      lastFocused = document.activeElement;
      setIndex(i);
      dialog.showModal();
    };

    const close = () => {
      dialog.close();
      if (lastFocused && typeof lastFocused.focus === "function") {
        lastFocused.focus();
      }
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const idx = Number(trigger.getAttribute("data-index"));
        open(Number.isFinite(idx) ? idx : 0);
      });
    });

    closeBtn.addEventListener("click", close);
    prevBtn.addEventListener("click", () => setIndex(currentIndex - 1));
    nextBtn.addEventListener("click", () => setIndex(currentIndex + 1));

    // Click on backdrop closes (click happens directly on the dialog,
    // not on .lb__inner)
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) close();
    });

    document.addEventListener("keydown", (e) => {
      if (!dialog.open) return;
      if (e.key === "ArrowLeft") {
        e.preventDefault();
        setIndex(currentIndex - 1);
      } else if (e.key === "ArrowRight") {
        e.preventDefault();
        setIndex(currentIndex + 1);
      }
      // ESC handled natively by <dialog>
    });

    dialog.addEventListener("close", () => {
      if (lastFocused && typeof lastFocused.focus === "function") {
        lastFocused.focus();
      }
    });
  })();
</script>
