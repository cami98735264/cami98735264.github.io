---
import { currentLocale } from "@i18n/locales";
import { loadTranslations } from "@i18n/index";
import ProjectDetailHeader from "./ProjectDetailHeader.astro";
import ProjectDetailBody from "./ProjectDetailBody.astro";
import NotFound from "@features/not-found/NotFound.astro";
import type { Project } from "./project.types";

const locale = currentLocale(Astro.currentLocale);
const t = await loadTranslations(locale);
const { projectid } = Astro.params;

const project = t.sections.projects.list.find(
  (p: Project) => String(p.id) === String(projectid),
);
---

{project ? (
  <>
    <ProjectDetailHeader
      project={{
        ...project,
        viewGithub: t.sections.projects.viewGithub,
        viewOnline: t.sections.projects.viewOnline,
      }}
    />
    <ProjectDetailBody
      project={project}
      highlightTitle={t.sections.projects.projectsNotes}
    />
  </>
) : (
  <NotFound />
)}
